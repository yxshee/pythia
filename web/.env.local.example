# Pythia ‚Äî web env vars.
#
# Copy to `.env.local` for `next dev`, OR set the same values in the
# Vercel project dashboard (Settings ‚Üí Environment Variables) for the
# deployed app. Defaults in `lib/contracts.ts` already point at the
# live Arc testnet deploy, so the app works without these vars set ‚Äî
# but setting them keeps deploys explicit and lets staging point at a
# fresh deploy without code changes.
#
# CRITICAL: ARC_RPC_URL is NOT a NEXT_PUBLIC_* variable. It contains a
# Canteen-issued secret token and must never be exposed to the browser.
# The wallet provides its own RPC to viem once the user connects.

NEXT_PUBLIC_UNLOCK_MARKET_ADDRESS=0x6478370B34Dc31498C68734EB2647C99A333b6D4
NEXT_PUBLIC_USDC_ADDRESS_ARC=0x6d3bda6e93dd02a1c237642C5af837796bF47511
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
