# Pythia — web env vars.
#
# Copy to `.env.local` for `next dev`, OR set the same values in the
# Vercel project dashboard (Settings → Environment Variables) for the
# deployed app. Defaults in `lib/contracts.ts` already point at the
# live Arc testnet deploy, so the public-facing pages work without
# these vars set — but the gated /api/traces/[id]/full route REQUIRES
# ARC_RPC_URL to be set or it will fail closed with 503.
#
# Public — safe to ship in the client bundle (addresses, chain id,
# block explorer URL). All four are address-shape constants.

NEXT_PUBLIC_UNLOCK_MARKET_ADDRESS=0xD8af5ebe36AC9eA736f40D749674FF1B0f4bd3cA
NEXT_PUBLIC_USDC_ADDRESS_ARC=0x6d3bda6e93dd02a1c237642C5af837796bF47511
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# Public site URL. Used by the wallet flow to point viem + MetaMask at
# the same-origin /api/rpc JSON-RPC proxy. Defaults to the prod URL when
# unset, so most environments don't need to set it. Override for local
# dev (e.g. http://localhost:3000) or non-prod Vercel previews.
NEXT_PUBLIC_SITE_URL=https://agoraalpha.vercel.app

# Server-only — MUST NOT be prefixed NEXT_PUBLIC_*. The Canteen-issued
# RPC URL embeds a secret token. It's read inside the Node.js runtime of
# (1) the /api/rpc proxy that the client uses for chain reads + chain-add
# payloads, and (2) the /api/traces/[id]/full route handler when checking
# UnlockMarket.isUnlocked + verifying the wallet signature. Setting
# this exposes the secret only to the function bundle, never to the
# browser.
ARC_RPC_URL=https://arc-node.thecanteenapp.com/v1/REPLACE_ME

# Server-only — points the paywall route at the Vercel Blob URL that
# holds the full paid bundle (picks-full.private.json). The URL embeds a
# random suffix, so the secret IS the URL; never expose it client-side.
# Local dev can leave this unset — the loader falls back to the on-disk
# `web/data/picks-full.private.json` snapshot when this is missing.
PRIVATE_TRACES_BLOB_URL=

# Server-only — Vercel Blob R/W token used by the agent's --upload-blob
# pipeline (scripts/upload-private-blob.mjs) and by any one-off blob
# operations. Never read by the Next.js runtime; never client-shipped.
# Pull from Vercel via `vercel env pull` or paste from the Vercel Storage
# dashboard. Format: `vercel_blob_rw_<store-id>_<secret>`.
BLOB_READ_WRITE_TOKEN=

# Server-only — Vercel KV REST credentials used for the paywall nonce
# store and the rate limiter. When unset, both fall back to in-memory
# Maps (fine for local dev, not durable on serverless). Pull from Vercel
# via `vercel env pull` or paste from the Vercel Storage dashboard.
KV_REST_API_URL=
KV_REST_API_TOKEN=
